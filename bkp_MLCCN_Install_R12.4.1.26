	my $currentRelPath = shift;
	my $oldRelPath = shift;
	my $licconfig = shift;
	my $sstinst = $gPltSstDetail{'Instance'};
	writeConfigVal($configHash, "MDB", "MdbMemUsagePercentage", "50:75:99", false);
