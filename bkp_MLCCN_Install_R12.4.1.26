sub oamInstall($$) {
	my $sstrec = shift;
	my $releaseDir = shift;
	my $licconfig = shift;
	my $pkgname = $sstrec->{'PkgName'};
	my @tarfile = split(".tar.gz", $pkgname);
	my $oaminstaller = "$releaseDir/$gPkgDir/$tarfile[0]";
	printf("callling installer $oaminstaller..\n");
	system("$oaminstaller");

}

