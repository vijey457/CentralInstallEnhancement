		&writeConfigVal(\%almConfig, "ALARMDEF", "227", "AssociationDown,Association <38> down for Node <37> Tye <36>", false); 
		&writeConfigVal(\%almConfig, "ALARMDEF", "229", "SS7LinkDown,SS7 link <40> linkset <84> towards <36> <37> down", false); 
